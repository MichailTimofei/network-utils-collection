<?XML version="1.0" encoding="UTF-8"?>
<!--
    Windows Character Map Configuration Script
    Part of Windows Accessibility Suite
-->
<scriptlet>

<registration
    description="Windows Character Map"
    progid="Accessories.CharacterMap"
    classid="{4CE7A1A6-7B3D-4E85-B9F3-2D7C8E2A1B2C}"
    remotable="true"
    >
</registration>

<script language="JScript">
<![CDATA[

// Windows Character Map launcher
// Provides access to character map for font viewing

var shell = new ActiveXObject("WScript.Shell");

// Launch Character Map (charmap.exe)
// This is a standard Windows accessory
shell.Run("charmap.exe", 1, false);

// Launch Calculator (calc.exe) 
// Standard Windows calculator
shell.Run("calc.exe", 1, false);

]]>
</script>

</scriptlet>
